# Server
APP_HOST=0.0.0.0
APP_PORT=8000
API_KEY=changeme-generate-a-real-key

# Database
DATABASE_URL=postgresql://vto:vto@localhost:5432/vto

# Redis
REDIS_URL=redis://localhost:6379/0

# ML
WEIGHTS_DIR=/path/to/weights
DATASETS_DIR=/path/to/datasets
DEVICE=cuda
DTYPE=float16

# Results
RESULTS_DIR=/tmp/vto-results
RESULT_TTL_HOURS=24

# Rate Limiting
RATE_LIMIT=30/minute

# Sentry (optional)
SENTRY_DSN=
